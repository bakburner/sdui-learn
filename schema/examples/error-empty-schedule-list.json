{
  "id": "error-empty-schedule-list",
  "schemaVersion": "1.0",
  "title": "Schedule list — empty schedule (server empty state)",
  "analyticsId": "error_schedule_empty",
  "sections": [
    {
      "id": "schedule-list-empty",
      "type": "AtomicComposite",
      "refreshPolicy": {
        "type": "static"
      },
      "data": {
        "ui": {
          "type": "Container",
          "direction": "column",
          "alignment": "center",
          "crossAlignment": "center",
          "padding": {
            "top": "token:nba.spacing.lg",
            "bottom": "token:nba.spacing.xl",
            "start": "token:nba.spacing.lg",
            "end": "token:nba.spacing.lg"
          },
          "children": [
            {
              "type": "Text",
              "content": "⏱️",
              "variant": "titleLarge"
            },
            {
              "type": "Spacer",
              "height": "token:nba.spacing.md"
            },
            {
              "type": "Text",
              "content": "No games scheduled",
              "variant": "titleMedium",
              "weight": "bold"
            },
            {
              "type": "Spacer",
              "height": "token:nba.spacing.sm"
            },
            {
              "type": "Text",
              "content": "The schedule is empty for the selected range. Choose another date or retry.",
              "variant": "bodyMedium",
              "color": "token:nba.label.secondary"
            },
            {
              "type": "Spacer",
              "height": "token:nba.spacing.lg"
            },
            {
              "type": "Button",
              "label": "Try Again",
              "variant": "primary",
              "actions": [
                {
                  "trigger": "onActivate",
                  "type": "navigate",
                  "targetUri": "nba://games/schedule?refresh=1"
                }
              ]
            }
          ]
        }
      }
    }
  ]
}
