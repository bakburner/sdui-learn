{
  "$comment": "Shadow elevation indices; clients map to platform shadow APIs. Values are unitless tiers for now — expand to structured offsets in a later version.",
  "$version": "0.1.0",
  "palette": {
    "shadow.raw.0": { "phone": 0, "phone.landscape": 0, "tablet": 0, "tv": 0, "web.narrow": 0, "web.wide": 0 },
    "shadow.raw.1": { "phone": 1, "phone.landscape": 1, "tablet": 1, "tv": 2, "web.narrow": 1, "web.wide": 1 },
    "shadow.raw.2": { "phone": 2, "phone.landscape": 2, "tablet": 2, "tv": 3, "web.narrow": 2, "web.wide": 2 },
    "shadow.raw.3": { "phone": 3, "phone.landscape": 3, "tablet": 3, "tv": 4, "web.narrow": 3, "web.wide": 3 }
  },
  "semantic": {
    "shadow.sm": { "aliasOf": "shadow.raw.1" },
    "shadow.md": { "aliasOf": "shadow.raw.2" },
    "shadow.lg": { "aliasOf": "shadow.raw.3" }
  }
}
