    "maxDate": "2026-06-30",
    "onDateSelected": {
      "trigger": "onActivate",
      "type": "refresh",
      "endpoint": "/v1/sdui/screen/games",
      "paramBindings": { "date": "{{games_selected_date}}" }
    }
  }
}
