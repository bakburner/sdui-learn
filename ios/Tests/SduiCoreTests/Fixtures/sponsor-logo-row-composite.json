{
  "id": "sponsor-logo-row-composite",
  "schemaVersion": "1.0",
  "title": "Sponsor / broadcast logo strip (minimal)",
  "analyticsId": "sponsor_logo_row_fixture",
  "sections": [
    {
      "id": "sponsor-row-section",
      "type": "AtomicComposite",
      "refreshPolicy": [
        {
          "type": "static"
        }
      ],
      "data": {
        "ui": {
          "id": "sponsor-row-root",
          "type": "Container",
          "direction": "row",
          "alignment": "center",
          "crossAlignment": "center",
          "gap": "token:nba.spacing.md",
          "padding": {
            "top": "token:nba.spacing.sm",
            "bottom": "token:nba.spacing.sm",
            "start": "token:nba.spacing.lg",
            "end": "token:nba.spacing.lg"
          },
          "children": [
            {
              "type": "Text",
              "content": "Presented by",
              "variant": "labelSmall",
              "color": "token:nba.label.tertiary"
            },
            {
              "type": "Image",
              "id": "broadcaster-a",
              "src": "https://example.com/broadcast/logo-a.png",
              "height": 24,
              "fit": "contain"
            },
            {
              "type": "Image",
              "id": "broadcaster-b",
              "src": "https://example.com/broadcast/logo-b.png",
              "height": 24,
              "fit": "contain"
            }
          ],
          "widthMode": "fill",
          "backgrounds": [
            "token:nba.bg.secondary"
          ]
        }
      }
    }
  ]
}
