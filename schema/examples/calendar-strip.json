{
  "id": "server:games-calendar~type=CalendarStrip",
  "type": "CalendarStrip",
  "contentSourceId": "server:games-calendar",
  "analyticsId": "games_calendar_strip",
  "accessibility": {
    "label": "Games date picker"
  },
  "data": {
    "stateKey": "games_selected_date",
    "selectedDate": "2026-05-25",
