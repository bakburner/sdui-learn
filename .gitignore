# Root project gitignore
.DS_Store
*.log
.idea/
*.iml

# Build outputs
build/
out/
target/
node_modules/

# Xcode / SwiftPM per-user and per-build state. `.swiftpm/` is Xcode's
# user-workspace-state directory (never shareable). `Package.resolved`
# at the library root is regenerated by `make ios-build` / `make ios-test`
# and conflicts with the demo project's own resolved file — leaving it
# uncommitted prevents the "Swift Package Proxy vs User Managed" Xcode 15
# bug from recurring across checkouts. The demo's shared resolved file
# at ios/SduiDemo/SduiDemo.xcodeproj/project.xcworkspace/xcshareddata/
# swiftpm/Package.resolved IS checked in deliberately — that one is the
# lockfile for the shipped app.
ios/.swiftpm/
ios/.build/
ios/Package.resolved
ios/SduiDemo/build/

# Environment files
.env
*.local

.trash/
.cursor/
.cursorrules
docs/page1.jpg
docs/page2.jpg
docs/page3.jpg
docs/discovery/
