              "tickDirection": "down",
              "stopAtSeconds": 0,
              "format": "m:ss"
            },
            {
              "id": "clock-running-up",
              "type": "LiveClock",
              "variant": "titleLarge",
              "snapshotSeconds": 0,
              "snapshotAt": "2026-01-15T20:30:00Z",
