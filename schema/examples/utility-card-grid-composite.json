{
  "id": "utility-card-grid-composite",
  "schemaVersion": "1.0",
  "title": "Discover utility grid (minimal)",
  "analyticsId": "utility_card_grid_fixture",
  "sections": [
    {
      "id": "utility-grid-section",
      "type": "AtomicComposite",
      "analyticsId": "utility_grid",
      "refreshPolicy": {
        "type": "static"
      },
      "data": {
        "ui": {
          "type": "Container",
          "direction": "column",
          "crossAlignment": "stretch",
          "gap": "token:nba.spacing.md",
          "padding": {
            "top": "token:nba.spacing.lg",
            "bottom": 0,
            "start": "token:nba.spacing.lg",
            "end": "token:nba.spacing.lg"
          },
          "children": [
            {
              "type": "Text",
              "content": "Around The League",
              "variant": "titleMedium",
              "weight": "bold",
              "color": "token:nba.label.primary"
            },
            {
              "type": "Container",
              "direction": "row",
              "crossAlignment": "stretch",
              "gap": "token:nba.spacing.md",
              "children": [
                {
                  "id": "util-a",
                  "type": "Container",
                  "direction": "column",
                  "crossAlignment": "center",
                  "gap": 8,
                  "background": "token:nba.bg.secondary",
                  "cornerRadius": 14,
                  "padding": {
                    "top": 14,
                    "bottom": 20,
                    "start": 14,
                    "end": "token:nba.spacing.lg"
                  },
                  "shadow": {
                    "color": "#00000014",
                    "radius": 4,
                    "offsetX": 0,
                    "offsetY": 2
                  },
                  "actions": [
                    {
                      "trigger": "onActivate",
                      "type": "navigate",
                      "targetUri": "nba://discover/util-a"
                    }
                  ],
                  "children": [
                    {
                      "type": "Image",
                      "src": "https://example.com/icons/standings.png",
                      "width": 44,
                      "height": 44,
                      "fit": "contain"
                    },
                    {
                      "type": "Text",
                      "content": "Standings",
                      "variant": "bodyMedium",
                      "weight": "semiBold",
                      "color": "token:nba.label.primary",
                      "maxLines": 2
                    }
                  ]
                },
                {
                  "id": "util-b",
                  "type": "Container",
                  "direction": "column",
                  "crossAlignment": "center",
                  "gap": 8,
                  "background": "token:nba.bg.secondary",
                  "cornerRadius": 14,
                  "padding": {
                    "top": 14,
                    "bottom": 20,
                    "start": 14,
                    "end": "token:nba.spacing.lg"
                  },
                  "shadow": {
                    "color": "#00000014",
                    "radius": 4,
                    "offsetX": 0,
                    "offsetY": 2
                  },
                  "actions": [
                    {
                      "trigger": "onActivate",
                      "type": "navigate",
                      "targetUri": "nba://discover/util-b"
                    }
                  ],
                  "children": [
                    {
                      "type": "Image",
                      "src": "https://example.com/icons/leaders.png",
                      "width": 44,
                      "height": 44,
                      "fit": "contain"
                    },
                    {
                      "type": "Text",
                      "content": "Leaders",
                      "variant": "bodyMedium",
                      "weight": "semiBold",
                      "color": "token:nba.label.primary",
                      "maxLines": 2
                    }
                  ]
                }
              ],
              "widthMode": "fill"
            }
          ]
        }
      }
