{
  "id": "game-schedule-row-composite",
  "schemaVersion": "1.0",
  "title": "Single game schedule row (GamePanel-aligned vertical teams)",
  "analyticsId": "game_schedule_row_fixture",
  "sections": [
    {
      "id": "schedule-row-section",
      "type": "AtomicComposite",
      "analyticsId": "schedule_row",
      "refreshPolicy": { "type": "static" },
      "data": {
        "ui": {
          "type": "Container",
          "direction": "column",
          "padding": { "top": 0, "bottom": 4, "start": 16, "end": 16 },
          "children": [
            {
              "id": "game-row-1",
              "type": "Container",
              "direction": "column",
              "crossAlignment": "stretch",
              "gap": 10,
              "background": "token:color.surface.raised",
              "cornerRadius": 12,
              "padding": { "top": 16, "bottom": 16, "start": 16, "end": 16 },
              "shadow": { "color": "#00000014", "radius": 4, "offsetX": 0, "offsetY": 2 },
              "actions": [
                {
                  "trigger": "onActivate",
                  "type": "navigate",
                  "targetUri": "nba://game/0022400001"
                }
              ],
              "children": [
                {
                  "type": "Container",
                  "direction": "row",
                  "alignment": "spaceBetween",
                  "crossAlignment": "center",
                  "fillWidth": true,
                  "children": [
                    {
                      "type": "Container",
                      "direction": "column",
                      "alignment": "center",
                      "crossAlignment": "center",
                      "width": 124,
                      "children": [
                        {
                          "type": "Image",
                          "src": "https://example.com/logos/nyk.png",
                          "width": 48,
                          "height": 48,
                          "fit": "contain"
                        },
                        { "type": "Spacer", "height": 4 },
                        {
                          "type": "Text",
                          "content": "3 NYK",
                          "variant": "titleMedium",
                          "weight": "semiBold",
                          "color": "token:color.text.primary",
                          "maxLines": 1
                        },
                        {
                          "type": "Text",
                          "content": "Knicks",
                          "variant": "labelSmall",
                          "color": "token:color.text.secondary",
                          "maxLines": 1
                        },
                        {
                          "type": "Text",
                          "content": "109",
                          "variant": "score",
                          "weight": "bold",
                          "color": "token:color.text.primary",
                          "maxLines": 1,
                          "monospacedDigits": true,
                          "bindRef": "game-row-1.awayScore"
                        }
                      ]
                    },
                    {
                      "type": "Container",
                      "direction": "column",
                      "crossAlignment": "center",
                      "width": 80,
                      "children": [
                        {
                          "type": "Text",
                          "content": "Final",
                          "variant": "labelSmall",
                          "weight": "semiBold",
                          "color": "token:color.text.secondary",
                          "textAlign": "center",
                          "maxLines": 2,
                          "bindRef": "game-row-1.statusText"
                        }
                      ]
                    },
                    {
                      "type": "Container",
                      "direction": "column",
                      "alignment": "center",
                      "crossAlignment": "center",
                      "width": 108,
                      "children": [
                        {
                          "type": "Image",
                          "src": "https://example.com/logos/bos.png",
                          "width": 48,
                          "height": 48,
                          "fit": "contain"
                        },
                        { "type": "Spacer", "height": 4 },
                        {
                          "type": "Text",
                          "content": "2 BOS",
                          "variant": "titleMedium",
                          "weight": "semiBold",
                          "color": "token:color.text.primary",
                          "maxLines": 1
                        },
                        {
                          "type": "Text",
                          "content": "Celtics",
                          "variant": "labelSmall",
                          "color": "token:color.text.secondary",
                          "maxLines": 1
                        },
                        {
                          "type": "Text",
                          "content": "132",
                          "variant": "score",
                          "weight": "bold",
                          "color": "token:color.text.primary",
                          "maxLines": 1,
                          "monospacedDigits": true,
                          "bindRef": "game-row-1.homeScore"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        "content": {
          "game-row-1": {
            "awayScore": 109,
            "homeScore": 132,
            "statusText": "Final"
          }
        }
      }
    }
  ]
}
